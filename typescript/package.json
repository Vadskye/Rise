{
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@stylistic/eslint-plugin": "^2.7.2",
    "@types/chai": "^4.2.12",
    "@types/lodash": "^4.14.136",
    "@types/mocha": "^8.0.3",
    "@types/node": "^10.17.60",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^4.13.0",
    "@typescript-eslint/parser": "^4.13.0",
    "chai": "^4.2.0",
    "eslint": "^9.9.1",
    "globals": "^15.9.0",
    "source-map-support": "^0.5.21",
    "tap": "^21.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslint": "^5.20.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  },
  "dependencies": {
    "change-case": "^3.1.0",
    "commander": "^3.0.0",
    "lodash": "^4.18.1"
  },
  "name": "rise",
  "version": "1.0.0",
  "main": "index.js",
  "author": "vadskye",
  "license": "OGL",
  "scripts": {
    "clean": "rm src/**/*.js",
    "coverage": "npx tsc --incremental && npx tap --node-arg=--import=tsx --exclude=**/*.js --coverage-report=text",
    "explain_monster": "npx tsc --incremental && node --import tsx src/scripts/explain_monster.js",
    "script": "npx tsc --incremental && node --enable-source-maps -r tsconfig-paths/register",
    "maneuver_ranks": "npx tsc --incremental && node --import tsx src/scripts/maneuver_rank_breakdown.js",
    "maneuver_roles": "npx tsc --incremental && node --import tsx src/scripts/maneuver_role_breakdown.js",
    "spell_ranks": "npx tsc --incremental && node --import tsx src/scripts/spell_rank_breakdown.js",
    "ritual_ranks": "npx tsc --incremental && node --import tsx src/scripts/ritual_rank_breakdown.js",
    "spell_roles": "npx tsc --incremental && node --import tsx src/scripts/spell_role_breakdown.js",
    "tap": "npx tsc --incremental && npx tap --node-arg=--import=tsx --exclude=**/*.js",
    "test": "npx tsc --incremental && npx tap --node-arg=--import=tsx --exclude=**/*.js"
  }
}